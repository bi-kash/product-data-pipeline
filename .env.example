# Database Configuration
USE_SQLITE=true
DB_HOST=localhost
DB_NAME=product_pipeline
DB_USER=your_username
DB_PASSWORD=your_password
DB_PORT=5432

# AliExpress API Configuration (via RapidAPI)
RAPIDAPI_KEY=71fbcd2e4cmsh0c6369dc03d68e4p108403jsne076fe9bec74
RAPIDAPI_HOST=aliexpress-true-api.p.rapidapi.com

# AliExpress API Region Settings
ALIEXPRESS_TARGET_CURRENCY=EUR
ALIEXPRESS_TARGET_LANGUAGE=EN
ALIEXPRESS_TARGET_COUNTRY=DE

# AliExpress Product Filtering
# Set minimum sale price to filter out low-priced items (in target currency)
# Leave empty to disable price filtering
MIN_SALE_PRICE=15


# USE_KEYWORDS controls the search strategy:
# 1. When USE_KEYWORDS=true:
#    - The harvester will search using BOTH keywords AND categories
#    - It will make separate API calls for each keyword and for categories
#    - Both approaches will be tracked in a single job_run record
#
# 2. When USE_KEYWORDS=false (RECOMMENDED):
#    - The harvester will search using ONLY categories
#    - This is often better: category-based search yields more complete results
#    - More efficient (fewer API calls)
#    - Avoids keyword-related biases that might include supplies
#
# To avoid harvesting jewelry supplies (beads, findings, etc.):
# - Set USE_KEYWORDS=false
# - Include only finished jewelry categories (200001680, 1509, etc.)
# - Exclude supply-focused categories (201238105, 200001478, etc.)
# - Use BLACKLIST_TERMS_IN_TITLE to automatically skip products with supply terms in their titles
USE_KEYWORDS=false
KEYWORDS=necklace,ring,bracelet,earrings,pendant,brooch,anklet

# Blacklist terms in product titles - products containing these terms will be automatically blacklisted
# When found in a product title:
# - Product status is set to BLACKLIST
# - Seller approval_status is set to BLACKLIST
# - Product is counted in blacklisted statistics
# Separate terms with commas, no spaces after commas
# These are excellent for filtering out jewelry supplies and components
BLACKLIST_TERMS_IN_TITLE=beads,findings,jump rings,clasps,wire,chain by the foot,jewelry making,diy jewelry

# Jewelry categories (AliExpress category IDs):
# RECOMMENDED CATEGORIES (focus on finished jewelry):
# 200001680 = Fine Jewelry
# 1509 = Fashion Jewelry
# 201239108 = Customized Jewelry
# 200370154 = Smart Jewelry
#
# CATEGORIES TO AVOID (primarily contain supplies, not finished jewelry):
# 36 = Jewelry & Accessories (parent, may include both finished and non-finished)
# 200001479 = Jewelry Packaging & Display
# 200001478 = Jewelry Tools & Equipments
# 201238105 = Jewelry Making
#
# Separate multiple category IDs with commas, no spaces
CATEGORIES=200001680,1509,201239108,200370154 # Only included most likely finished jewelry categories

# AliExpress Official API Session Management
# Set this to enable official AliExpress API integration (for future use)
USE_TOKEN_VALIDATION=false
# URL for the AliExpress API (default official URL)
IOP_URL=https://api-sg.aliexpress.com/rest
# Your AliExpress app credentials
IOP_APPKEY=your_app_key_here
IOP_APPSECRET=your_app_secret_here
# Session code to use for API calls (set after creating a session)
ALIEXPRESS_SESSION_CODE=your_session_code_here

LOG_LEVEL=INFO
RATE_LIMIT_DELAY=1
MAX_RETRIES=3
TIMEOUT=30
USE_MOCK_DATA=false
API_PAGE_SIZE=50