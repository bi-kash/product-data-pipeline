# Database Configuration
USE_SQLITE=true
DB_HOST=localhost
DB_NAME=product_pipeline
DB_USER=your_username
DB_PASSWORD=your_password
DB_PORT=5432

# AliExpress API Configuration (via RapidAPI)
RAPIDAPI_KEY=Your Rapid API key
RAPIDAPI_HOST=aliexpress-true-api.p.rapidapi.com

# AliExpress API Region Settings
ALIEXPRESS_TARGET_CURRENCY=EUR
ALIEXPRESS_TARGET_LANGUAGE=EN
ALIEXPRESS_TARGET_COUNTRY=DE


# USE_KEYWORDS controls whether product search uses keywords or only categories.
# If USE_KEYWORDS=false, the harvester will search using only the CATEGORIES below and will NOT limit results by specific keywords.
# This is often advantageous: searching only by category can yield a broader set of finished jewelry products,
# as keyword-based search may miss relevant items or bias results toward supplies.
# To avoid supplies, carefully curate the CATEGORIES list below to include only finished jewelry categories.
# You can always adjust this setting and the category list as needed.
USE_KEYWORDS=false # search directly using jewelry related categories below if false
KEYWORDS=necklace,ring,bracelet,earrings,pendant necklace,brooch,anklet

# Jewelry categories (AliExpress category IDs):
# 200001680 = Fine Jewelry
# 1509 = Fashion Jewelry
# 201239108 = Customized Jewelry
# 200370154 = Smart Jewelry
# 36 = Jewelry & Accessories (parent, may include both finished and non-finished)
# 200001479 = Jewelry Packaging & Display (likely NOT finished jewelry)
# 200001478 = Jewelry Tools & Equipments (likely NOT finished jewelry)
# 201238105 = Jewelry Making (likely NOT finished jewelry)
CATEGORIES=200001680,1509,201239108,200370154. # Only included most likely finished jewelry categories
LOG_LEVEL=INFO
RATE_LIMIT_DELAY=1
MAX_RETRIES=3
TIMEOUT=30
USE_MOCK_DATA=false
API_PAGE_SIZE=50